# 🦆 DevDuck environment configuration
# Copy to .env and fill in what you need. All values are optional — DevDuck
# auto-detects model provider and gracefully skips features without keys.

# =============================================================================
# MODEL PROVIDERS (pick one — auto-detected in this priority order)
# =============================================================================

# 1. AWS Bedrock (preferred — Claude, Nova)
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-west-2

# 2. Anthropic direct
ANTHROPIC_API_KEY=

# 3. OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_ID=

# 4. GitHub Models
GITHUB_TOKEN=
PAT_TOKEN=

# 5. Google Gemini
GOOGLE_API_KEY=
GEMINI_API_KEY=

# 6. Others
COHERE_API_KEY=
WRITER_API_KEY=
MISTRAL_API_KEY=
LITELLM_API_KEY=
LLAMAAPI_API_KEY=
SAGEMAKER_ENDPOINT_NAME=
LLAMACPP_MODEL_PATH=

# 7. Ollama (local fallback)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=

# Model overrides
MODEL_PROVIDER=
STRANDS_MODEL_ID=
STRANDS_MAX_TOKENS=60000
STRANDS_TEMPERATURE=1.0

# Speech-to-speech models
NOVA_SONIC_MODEL_ID=
BIDI_MODEL_ID=

# =============================================================================
# SERVERS (auto-start on launch)
# =============================================================================
DEVDUCK_AUTO_START_SERVERS=true
DEVDUCK_ENABLE_WS=true            # WebSocket (port 10001)
DEVDUCK_ENABLE_ZENOH=true         # P2P multicast mesh
DEVDUCK_ENABLE_TCP=false          # Raw TCP (port 10002)
DEVDUCK_ENABLE_MCP=false          # MCP HTTP (port 10003)
DEVDUCK_ENABLE_IPC=false          # Unix socket
DEVDUCK_ENABLE_ZCM=false          # ZCM robotics transport

DEVDUCK_WS_PORT=10001
DEVDUCK_TCP_PORT=10002
DEVDUCK_MCP_PORT=10003
DEVDUCK_AGENTCORE_PROXY_PORT=10000
DEVDUCK_WS_API_KEY=               # Optional auth for WebSocket

# Zenoh remote peering (leave empty for LAN multicast only)
ZENOH_CONNECT=                    # e.g. tcp/home.example.com:7447
ZENOH_LISTEN=                     # e.g. tcp/0.0.0.0:7447
ZCM_TRANSPORT_URL=                # e.g. udpm://239.255.76.67:7667

# =============================================================================
# TOOLS & BEHAVIOR
# =============================================================================
BYPASS_TOOL_CONSENT=true
DEVDUCK_TOOLS=                    # Override default tool set
DEVDUCK_LOAD_TOOLS_FROM_DIR=true  # Hot-reload ./tools/*.py
DEVDUCK_LOG_LINE_COUNT=50
DEVDUCK_LAST_MESSAGE_COUNT=200
DEVDUCK_RESPONSE_SUMMARY_LENGTH=10000
DEVDUCK_HOME=                     # Default: ~/.devduck
DEVDUCK_IDENTITY_DB=              # Default: ~/.devduck/identities.db

# Knowledge base (Bedrock RAG)
DEVDUCK_KNOWLEDGE_BASE_ID=
STRANDS_KNOWLEDGE_BASE_ID=

# =============================================================================
# AMBIENT / AUTONOMOUS MODE
# =============================================================================
DEVDUCK_AMBIENT_MODE=false
DEVDUCK_AMBIENT_IDLE_SECONDS=30
DEVDUCK_AMBIENT_MAX_ITERATIONS=15
DEVDUCK_AMBIENT_COOLDOWN=60
DEVDUCK_AUTONOMOUS_MAX_ITERATIONS=100
DEVDUCK_AUTONOMOUS_COOLDOWN=10

# =============================================================================
# INTEGRATIONS
# =============================================================================

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=           # Comma-separated IDs/usernames
STRANDS_TELEGRAM_AUTO_REPLY=false
STRANDS_TELEGRAM_LISTEN_ONLY_TAG=
TELEGRAM_DEFAULT_EVENT_COUNT=20

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USERS=
STRANDS_SLACK_AUTO_REPLY=false
STRANDS_SLACK_LISTEN_ONLY_TAG=
SLACK_DEFAULT_EVENT_COUNT=20

# WhatsApp (via wacli)
WACLI_STORE=
WACLI_BINARY=
WHATSAPP_ALLOWED_SENDERS=
STRANDS_WHATSAPP_AUTO_REPLY=false
WHATSAPP_POLL_INTERVAL=5
WHATSAPP_POLL_LIMIT=20
WHATSAPP_SYNC_INTERVAL=60

# GitHub
GITHUB_REPOSITORY=                # owner/repo default
GITHUB_AGENT_REPOS=

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# =============================================================================
# MCP CLIENTS (load external MCP servers as tools)
# =============================================================================
# JSON string with "mcpServers" key
# Example: {"mcpServers": {"strands": {"command": "uvx", "args": ["strands-agents-mcp-server"]}}}
MCP_SERVERS=

# =============================================================================
# ADVANCED / DEV
# =============================================================================
DEVDUCK_TUI_MAX_SHARED_MESSAGES=100
DEVDUCK_FAN_OUT_MAX_WORKERS=10
DEVDUCK_SCHEDULER_CATCHUP=true
DEVDUCK_TUNNEL_AUTO=false         # Auto-open Cloudflare tunnels
DEVDUCK_TUNNEL_PORTS=             # e.g. 10000,10001

# LSP auto-diagnostics
DEVDUCK_LSP_AUTO_DIAGNOSTICS=false
DEVDUCK_LSP_SERVERS=

# RL / ML
DEVDUCK_ML_MODELS_DIR=
DEVDUCK_RL_ENVS_DIR=
DEVDUCK_RL_MODELS_DIR=
DEVDUCK_RL_LOGS_DIR=
DEVDUCK_RL_TENSORBOARD=

# Misc
DEVDUCK_CHROME_EXTENSION_ID=
FLIPPER_PORT=
JSONRPC_ENDPOINT=
DEVDUCK_ASCIINEMA=false
DEVDUCK_CAST_DIR=
DEVDUCK_LISTEN_MIN_DURATION=
